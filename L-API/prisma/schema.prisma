// Prisma schema for L-API (MySQL).
// 文档: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Auth.js (NextAuth v5) 模型
// ---------------------------------------------------------------------------

enum Role {
  USER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  // 自定义字段
  password String? // bcrypt 哈希；OAuth 用户可为空
  role     Role    @default(USER)
  credits  Int     @default(0)

  accounts         Account[]
  sessions         Session[]
  apiKeys          ApiKey[]
  requestLogs      RequestLog[]
  orders           Order[]
  hotSubscription  HotSubscription?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// API 目录
// ---------------------------------------------------------------------------

enum ApiStatus {
  ACTIVE
  BETA
  DEPRECATED
}

model ApiCategory {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String? @db.Text
  icon        String?
  order       Int     @default(0)
  apis        Api[]
  createdAt   DateTime @default(now())
}

model Api {
  id             String      @id @default(cuid())
  slug           String      @unique
  name           String
  summary        String      @db.Text
  description    String?     @db.Text
  method         String      @default("GET")
  path           String
  pricePerCall   Int         @default(1)
  status         ApiStatus   @default(ACTIVE)
  popularity     Int         @default(0)
  featured       Boolean     @default(false)
  params         Json?
  sampleResponse Json?

  categoryId String
  category   ApiCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  requestLogs RequestLog[]
  hotItems    HotItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
}

// ---------------------------------------------------------------------------
// API 密钥
// ---------------------------------------------------------------------------

enum KeyStatus {
  ACTIVE
  REVOKED
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  name       String
  prefix     String    @unique
  hash       String
  lastUsedAt DateTime?
  status     KeyStatus @default(ACTIVE)

  // 安全增强
  scopes          String?   @db.Text // 逗号分隔的分类 slug，空=全部
  expiresAt       DateTime? // 过期时间，空=永不过期
  rateLimitPerMin Int? // 每分钟调用上限覆盖，空=使用全局策略
  dailyQuota      Int? // 该密钥每日调用上限，空=不单独限制

  createdAt DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  requestLogs RequestLog[]

  @@index([userId])
}

// ---------------------------------------------------------------------------
// 请求日志
// ---------------------------------------------------------------------------

model RequestLog {
  id          String   @id @default(cuid())
  userId      String
  apiId       String?
  apiKeyId    String?
  endpoint    String
  statusCode  Int
  latencyMs   Int
  creditsCost Int      @default(0)
  createdAt   DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  api    Api?    @relation(fields: [apiId], references: [id], onDelete: SetNull)
  apiKey ApiKey? @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([apiId])
}

// 每日用量汇总（由日志异步批量增量写入，供仪表盘聚合查询，避免扫全量日志）。
model UsageDaily {
  id           String   @id @default(cuid())
  date         DateTime // 当日 0 点（UTC）
  userId       String
  apiId        String?
  requests     Int      @default(0)
  errors       Int      @default(0)
  creditsCost  Int      @default(0)
  latencySumMs Int      @default(0)

  @@unique([date, userId, apiId])
  @@index([userId, date])
}

// ---------------------------------------------------------------------------
// 计费 / 积分
// ---------------------------------------------------------------------------

enum OrderStatus {
  PENDING
  PAID
  FAILED
}

model CreditPackage {
  id        String  @id @default(cuid())
  slug      String  @unique
  name      String
  credits   Int
  priceCents Int
  bonus     Int     @default(0)
  popular   Boolean @default(false)
  order     Int     @default(0)
  orders    Order[]
  createdAt DateTime @default(now())
}

model Order {
  id          String      @id @default(cuid())
  userId      String
  packageId   String?
  credits     Int
  amountCents Int
  status      OrderStatus @default(PAID)
  createdAt   DateTime    @default(now())

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  package CreditPackage? @relation(fields: [packageId], references: [id], onDelete: SetNull)

  @@index([userId])
}

// ---------------------------------------------------------------------------
// 每日热榜
// ---------------------------------------------------------------------------

model HotItem {
  id    String   @id @default(cuid())
  apiId String
  date  DateTime
  rank  Int
  calls Int      @default(0)
  trend Int      @default(0)

  api Api @relation(fields: [apiId], references: [id], onDelete: Cascade)

  @@unique([apiId, date])
  @@index([date, rank])
}

model HotSubscription {
  id        String   @id @default(cuid())
  userId    String   @unique
  channel   String   @default("email")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// 安全 / 风控审计
// ---------------------------------------------------------------------------

model SecurityEvent {
  id         String   @id @default(cuid())
  type       String // RATE_LIMIT | QUOTA | BAN | LOGIN_LOCK | ABUSE | POLICY
  scope      String // ip | key | user | login | register | admin
  identifier String
  detail     String?  @db.Text
  userId     String?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([createdAt])
}

// 超管可在后台编辑的限流/风控策略（覆盖代码默认值）。
model SecurityPolicy {
  key       String   @id // apiPerKey / apiPerIp / demoPerIp / register / dailyQuota / login / apiKey
  kind      String // throughput | abuse
  enabled   Boolean  @default(true)
  limit     Int? // throughput：窗口内最大次数
  threshold Int? // abuse：触发封禁的失败次数
  windowMs  Int
  banMs     Int? // abuse：封禁时长
  updatedAt DateTime @updatedAt @default(now())
}
