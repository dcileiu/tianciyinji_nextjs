# 微信支付商户配置（必填）
WECHAT_APPID=
WECHAT_MCH_ID=
WECHAT_PAY_SERIAL_NO=
# 商户 API 私钥 PEM；多行可写成 \n 形式
WECHAT_PAY_PRIVATE_KEY=
# APIv3 密钥，必须 32 字节
WECHAT_PAY_API_V3_KEY=

# getPayConfig() 会校验此变量；H5/Native 实际走各自 notify URL，此处可填 H5 或 Native 回调地址
WECHAT_PAY_NOTIFY_URL=https://your-domain.com/api/pay/h5/notify

# 可选：H5 场景页 URL（默认当前域名首页）
# WECHAT_PAY_H5_APP_URL=https://your-domain.com/
# 可选：H5 回调（默认 {域名}/api/pay/h5/notify）
# WECHAT_PAY_H5_NOTIFY_URL=https://your-domain.com/api/pay/h5/notify
# 可选：Native 回调（默认 {域名}/api/pay/native/notify）
# WECHAT_PAY_NATIVE_NOTIFY_URL=https://your-domain.com/api/pay/native/notify

# 可选：下单描述与 H5 场景名称
# WECHAT_PAY_APP_NAME=我的应用
# WECHAT_PAY_H5_DESCRIPTION=H5支付测试
# WECHAT_PAY_NATIVE_DESCRIPTION=Native扫码支付测试

# 可选：保护创建/查单 API（请求头 x-api-secret）；留空则不校验
# PAY_DEMO_API_SECRET=

PORT=3000
